body {
  margin: 0;
  font-family: sans-serif;
  background: #0f172a;
  color: white;
}

/* NAV */
.nav {
  padding: 20px;
  font-weight: bold;
}

/* HERO */
.hero {
  display: flex;
  justify-content: space-between;
  padding: 40px;
  align-items: center;
}

.profile {
  width: 260px;
  border-radius: 20px;
  transform: rotateY(-10deg);
  transition: 0.3s;
}

.profile:hover {
  transform: rotateY(0deg) scale(1.05);
}

/* MUSIC GRID */
.grid {
  display: flex;
  gap: 20px;
  padding: 20px;
}

.card {
  width: 200px;
  height: 200px;
  background: linear-gradient(145deg, #1e293b, #0f172a);
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: 0.3s;
}

.card:hover {
  transform: scale(1.1) rotateX(10deg);
}

/* PLAYER */
.player {
  position: fixed;
  bottom: 0;
  width: 100%;
  background: #111;
  padding: 10px;
}

/* CONTACT */
.contact {
  padding: 40px;
}

.contact a {
  margin-right: 20px;
  color: white;
  text-decoration: none;
}
